# Keep dataset index txt files under images/ in the repository.
extra_data/
images/chinese/bac/
images/chinese/0-5/

# Process archive is useful locally, but contains old model packages,
# duplicated datasets and exploratory scripts. Keep final docs instead.
实验过程归档/misc/
实验过程归档/models_old/
实验过程归档/docs_old/

# OS noise
Thumbs.db
.DS_Store
